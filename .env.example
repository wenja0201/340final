# Copy this file to .env (local dev) and set the same keys in the Vercel
# Project → Settings → Environment Variables for Preview & Production.
# Vite only exposes variables prefixed with VITE_ to the browser — never put
# a secret/write-scoped token in one of these.

# ── Password gate (src/components/PasswordGate.tsx) ─────────────────────────
# Temporary client-preview lock. Remove the gate entirely once the site is
# approved and goes live for real.
VITE_SITE_PASSWORD=

# ── Strapi CMS ───────────────────────────────────────────────────────────────
# Public base URL of the Strapi instance, no trailing slash.
#   e.g. https://cms.340consultancy.com  (or the Strapi Cloud URL)
VITE_STRAPI_URL=

# Optional. Only set this if a content type's "find"/"findOne" permission is
# NOT public in Strapi (Settings → Users & Permissions → Roles → Public) and
# the site needs to read it anyway — e.g. for previewing draft content.
# Use a token scoped to read-only. Anything in a VITE_ variable ships to the
# browser in plain text, so never put an admin or full-access token here.
VITE_STRAPI_TOKEN=
